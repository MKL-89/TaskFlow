<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.TaskFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="Theme.TaskFlow" parent="Base.Theme.TaskFlow" />

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DarkDialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:background">@color/card_bg</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:windowBackground">@color/card_bg</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="DarkDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

</resources>